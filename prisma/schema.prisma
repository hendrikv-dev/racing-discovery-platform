generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum RaceStatus {
  LIVE
  UPCOMING
  COMPLETED
}

enum RaceSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  CONVERTED
}

enum NotificationType {
  RACE_STARTING_SOON
  NEW_RACE_IN_FOLLOWED_CHAMPIONSHIP
  RESULT_AVAILABLE
}

model User {
  id                    String                @id @default(cuid())
  name                  String?
  email                 String?               @unique
  passwordHash          String?
  emailVerified         DateTime?
  image                 String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  accounts              Account[]
  sessions              Session[]
  trackedRaces          TrackedRace[]
  trackedRacers         TrackedRacer[]
  trackedTracks         TrackedTrack[]
  trackedChampionships  TrackedChampionship[]
  notifications         Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Championship {
  id          String               @id @default(cuid())
  slug        String               @unique
  name        String
  category    String
  region      String
  season      String
  description String
  image       String
  accentColor String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  races       Race[]
  racers      Racer[]
  submissions RaceSubmission[]
  trackedBy   TrackedChampionship[]
}

model Track {
  id         String         @id @default(cuid())
  slug       String         @unique
  name       String
  location   String
  country    String
  trackType  String
  length     String
  turns      Int
  lapRecord  String
  image      String
  history    String
  website    String?
  latitude   Float
  longitude  Float
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  races      Race[]
  submissions RaceSubmission[]
  trackedBy  TrackedTrack[]
}

model Racer {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  team          String
  nationality   String
  number        String
  championships Int
  victories     Int
  podiums       Int
  bio           String?
  image         String
  vehicle       String
  verified      Boolean        @default(false)
  championshipId String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  championship  Championship?  @relation(fields: [championshipId], references: [id], onDelete: SetNull)
  raceEntries   RaceEntry[]
  trackedBy     TrackedRacer[]
}

model Race {
  id             String         @id @default(cuid())
  slug           String         @unique
  name           String
  series         String
  location       String
  status         RaceStatus
  summary        String
  startDate      DateTime
  endDate        DateTime
  latitude       Float
  longitude      Float
  championshipId String
  trackId        String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  championship   Championship   @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  track          Track          @relation(fields: [trackId], references: [id], onDelete: Cascade)
  submission     RaceSubmission?
  entries        RaceEntry[]
  trackedBy      TrackedRace[]
}

model RaceEntry {
  id             String   @id @default(cuid())
  raceId         String
  racerId        String
  finishPosition Int?
  createdAt      DateTime @default(now())
  race           Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  racer          Racer    @relation(fields: [racerId], references: [id], onDelete: Cascade)

  @@unique([raceId, racerId])
}

model TrackedRace {
  id        String   @id @default(cuid())
  userId    String
  raceId    String
  createdAt DateTime @default(now())
  race      Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, raceId])
}

model TrackedRacer {
  id        String   @id @default(cuid())
  userId    String
  racerId   String
  createdAt DateTime @default(now())
  racer     Racer    @relation(fields: [racerId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, racerId])
}

model TrackedTrack {
  id        String   @id @default(cuid())
  userId    String
  trackId   String
  createdAt DateTime @default(now())
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
}

model TrackedChampionship {
  id             String        @id @default(cuid())
  userId         String
  championshipId String
  createdAt      DateTime      @default(now())
  championship   Championship  @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, championshipId])
}

model WaitlistSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model RaceSubmission {
  id             String               @id @default(cuid())
  eventName      String
  series         String
  eventDate      DateTime
  circuit        String
  description    String
  sourceNotes    String?
  contactEmail   String?
  status         RaceSubmissionStatus @default(PENDING)
  approvedAt     DateTime?
  convertedAt    DateTime?
  championshipId String?
  trackId        String?
  raceId         String?              @unique
  latitude       Float?
  longitude      Float?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  championship   Championship?        @relation(fields: [championshipId], references: [id], onDelete: SetNull)
  track          Track?               @relation(fields: [trackId], references: [id], onDelete: SetNull)
  race           Race?                @relation(fields: [raceId], references: [id], onDelete: SetNull)
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  entityId  String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}
